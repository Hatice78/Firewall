# ZERO-TRUST SESSION MANAGER

# ═══════════════════════════════════════════════════════════════════════════════


@dataclass

class ZeroTrustSession:

    """Eine Zero-Trust-Sitzung"""

    session_id: str

    user_id: str

    source_ip: str

    created_at: datetime

    last_verified: datetime

    trust_score: float

    verification_count: int = 0

    is_active: bool = True

    

    @property

    def is_expired(self) -> bool:

        return datetime.now() - self.last_verified > CONFIG.SESSION_TIMEOUT

    

    @property

    def needs_reauth(self) -> bool:

        return datetime.now() - self.last_verified > CONFIG.REAUTHENTICATION_INTERVAL


class ZeroTrustManager:

    """

    Never Trust, Always Verify

    Kontinuierliche Verifizierung aller Sitzungen

    """

    

    def __init__(self, crypto: QuantumSafeCrypto):

        self.sessions: Dict[str, ZeroTrustSession] = {}

        self.crypto = crypto

        self._lock = asyncio.Lock()

        self._session_history: deque = deque(maxlen=100000)

    

    async def create_session(self, user_id: str, source_ip: str) -> ZeroTrustSession:

        """Erstellt eine neue Zero-Trust-Sitzung"""

        session_id = secrets.token_urlsafe(32)

        session = ZeroTrustSession(

            session_id=session_id,

            user_id=user_id,

            source_ip=source_ip,

            created_at=datetime.now(),

            last_verified=datetime.now(),

            trust_score=0.5  # Neutral starten

        )

        

        async with self._lock:

            self.sessions[session_id] = session

        

        return session

    

    async def verify_session(self, session_id: str, 

                            behavioral_data: Dict[str, Any]) -> Tuple[bool, float]:

        """Kontinuierliche Verifizierung einer Sitzung"""

        async with self._lock:

            session = self.sessions.get(session_id)

            if not session or not session.is_active:

                return False, 0.0

            

            if session.is_expired:

                session.is_active = False

                return False, 0.0

            

            # Behavioral Biometrics Verification

            trust_delta = self._calculate_trust_delta(session, behavioral_data)

            session.trust_score = max(0.0, min(1.0, session.trust_score + trust_delta))

            session.last_verified = datetime.now()

            session.verification_count += 1

            

            # Dynamische Sicherheitsstufe

            if session.trust_score < 0.3:

                return False, session.trust_score

            elif session.trust_score < 0.7:

                return True, session.trust_score  # Eingeschränkter Zugriff

            else:

                return True, session.trust_score  # Voller Zugriff

    

    def _calculate_trust_delta(self, session: ZeroTrustSession, 

                               data: Dict[str, Any]) -> float:

        """Berechnet die Trust-Score-Änderung"""

        delta = 0.0

        

        # IP-Konsistenz

        if data.get('source_ip') != session.source_ip:

            delta -= 0.3

        

        # Timing-Konsistenz

        expected_interval = data.get('expected_interval', 60)

        actual_interval = data.get('actual_interval', 60)

        if abs(actual_interval - expected_interval) > 10:

            delta -= 0.1

        else:

            delta += 0.05

        

        # Device Fingerprint

        if data.get('device_fingerprint') != data.get('expected_fingerprint'):

            delta -= 0.2

        

        # Geolocation

        if data.get('geo_risk', 0.0) > 0.5:

            delta -= 0.15

        

        return delta

    

    async def revoke_session(self, session_id: str, reason: str):

        """Widerruft eine Sitzung sofort"""

        async with self._lock:

            if session_id in self.sessions:

                self.sessions[session_id].is_active = False

                self._session_history.append({

                    'session_id': session_id,

                    'revoked_at': datetime.now().isoformat(),

                    'reason': reason

                })


