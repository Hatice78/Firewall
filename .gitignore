@dataclass

class AuditBlock:

    """Ein Block in der Audit-Blockchain"""

    index: int

    timestamp: str

    event_type: str

    source_ip: str

    action_taken: str

    threat_level: float

    agent_consensus: Dict[str, float]

    previous_hash: str

    nonce: int = 0

    hash: str = ""

    

    def calculate_hash(self) -> str:

        """Berechnet den Block-Hash"""

        block_string = json.dumps({

            'index': self.index,

            'timestamp': self.timestamp,

            'event_type': self.event_type,

            'source_ip': self.source_ip,

            'action_taken': self.action_taken,

            'threat_level': self.threat_level,

            'agent_consensus': self.agent_consensus,

            'previous_hash': self.previous_hash,

            'nonce': self.nonce

        }, sort_keys=True)

        return hashlib.sha3_256(block_string.encode()).hexdigest()

    

    def mine_block(self, difficulty: int):

        """Proof-of-Work für Block-Validierung"""

        target = "0" * difficulty

        while not self.hash.startswith(target):

            self.nonce += 1

            self.hash = self.calculate_hash()


class AuditBlockchain:

    """Unveränderliche Audit-Kette"""

    

    def __init__(self, crypto: QuantumSafeCrypto):

        self.chain: List[AuditBlock] = []

        self.crypto = crypto

        self.difficulty = CONFIG.BLOCKCHAIN_DIFFICULTY

        self._lock = asyncio.Lock()

        self._create_genesis_block()

    

    def _create_genesis_block(self):

        """Erstellt den Genesis-Block"""

        genesis = AuditBlock(

            index=0,

            timestamp=datetime.now().isoformat(),

            event_type="GENESIS",

            source_ip="0.0.0.0",

            action_taken="SYSTEM_INITIALIZATION",

            threat_level=0.0,

            agent_consensus={},

            previous_hash="0" * 64

        )

        genesis.mine_block(self.difficulty)

        self.chain.append(genesis)

    

    async def add_block(self, event_type: str, source_ip: str, 

                       action_taken: str, threat_level: float,

                       agent_consensus: Dict[str, float]) -> AuditBlock:

        """Fügt einen neuen Block zur Kette hinzu"""

        async with self._lock:

            previous_block = self.chain[-1]

            new_block = AuditBlock(

                index=len(self.chain),

                timestamp=datetime.now().isoformat(),

                event_type=event_type,

                source_ip=source_ip,

                action_taken=action_taken,

                threat_level=threat_level,

                agent_consensus=agent_consensus,

                previous_hash=previous_block.hash

            )

            new_block.mine_block(self.difficulty)

            

            # Signiere den Block

            block_data = new_block.hash.encode()

            signature = self.crypto.sign(block_data)

            

            self.chain.append(new_block)

            return new_block

    

    def verify_integrity(self) -> bool:

        """Prüft die Integrität der gesamten Kette"""

        for i in range(1, len(self.chain)):

            current = self.chain[i]

            previous = self.chain[i - 1]

            

            if current.hash != current.calculate_hash():

                return False

            if current.previous_hash != previous.hash:

                return False

            if not current.hash.startswith("0" * self.difficulty):

                return False

        

        return True

    

    def get_evidence(self, source_ip: str) -> List[AuditBlock]:

        """Holt alle Beweise für eine bestimmte IP"""

        return [block for block in self.chain if block.source_ip == source_ip]


