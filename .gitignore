# HONEYPOT & DECEPTION LAYER

# ═══════════════════════════════════════════════════════════════════════════════


class DeceptionEngine:

    """

    Aktive Täuschung und Verzögerung von Angreifern

    """

    

    def __init__(self):

        self.honeypots: Set[str] = set()

        self.fake_services: Dict[int, str] = {}

        self._trap_responses = self._generate_trap_responses()

    

    def _generate_trap_responses(self) -> Dict[str, bytes]:

        """Generiert täuschend echte Antworten"""

        return {

            'ssh': b"SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.1\\r\\n",

            'http': b"HTTP/1.1 200 OK\\r\\nServer: Apache/2.4.41\\r\\n\\r\\n",

            'ftp': b"220 Welcome to FTP Server\\r\\n",

            'telnet': b"\\xff\\xfb\\x01\\xff\\xfb\\x03\\xff\\xfd\\x18\\xff\\xfd\\x1f"

        }

    

    async def deploy_honeypot(self, port: int, service_type: str) -> bool:

        """Deployt einen Honeypot auf einem Port"""

        try:

            self.fake_services[port] = service_type

            self.honeypots.add(f"0.0.0.0:{port}")

            return True

        except Exception:

            return False

    

    async def handle_deception(self, reader, writer, service_type: str):

        """Behandelt einen Honeypot-Kontakt"""

        ip = writer.get_extra_info('peername')[0]

        

        # Sende täuschende Antwort

        response = self._trap_responses.get(service_type, b"")

        writer.write(response)

        await writer.drain()

        

        # Sammle Informationen

        try:

            data = await asyncio.wait_for(reader.read(4096), timeout=5.0)

            # Logge den Angriffsversuch

            return {

                'source_ip': ip,

                'service': service_type,

                'payload_sample': data[:100].hex(),

                'timestamp': datetime.now().isoformat()

            }

        except asyncio.TimeoutError:

            return None

        finally:

            writer.close()


