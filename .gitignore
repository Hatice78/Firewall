@dataclass

class ThreatSignature:

    """Bedrohungssignatur für ML-Analyse"""

    source_ip: str

    packet_size: int

    frequency: float

    timing_pattern: List[float]

    payload_entropy: float

    protocol_anomaly: float

    geolocation_risk: float

    reputation_score: float

    timestamp: datetime = field(default_factory=datetime.now)

    

    def to_vector(self) -> np.ndarray:

        """Konvertiert zu Feature-Vektor"""

        return np.array([

            self.packet_size / 1500.0,  # Normalisiert

            min(self.frequency / 100.0, 1.0),

            np.std(self.timing_pattern) if self.timing_pattern else 0.0,

            self.payload_entropy / 8.0,

            self.protocol_anomaly,

            self.geolocation_risk,

            self.reputation_score

        ])


class AIAgentSwarm:

    """

    Multi-Agent Defense Grid

    Jeder Agent spezialisiert sich auf eine Bedrohungskategorie

    """

    

    def __init__(self):

        self.agents: Dict[str, 'DefenseAgent'] = {}

        self.consensus_threshold = 0.7

        self._initialize_agents()

        self._threat_memory: deque = deque(maxlen=10000)

        self._model_lock = asyncio.Lock()

        

        # Deep Learning Model (falls PyTorch verfügbar)

        self.neural_net = self._build_neural_network()

        

        # Ensemble Model

        self.ensemble = self._build_ensemble()

        

        # Behavioral Baseline

        self.behavioral_baseline: Dict[str, deque] = defaultdict(

            lambda: deque(maxlen=CONFIG.BEHAVIORAL_WINDOW_SIZE)

        )

    

    def _build_neural_network(self) -> Optional[nn.Module]:

        """Deep Neural Network für komplexe Bedrohungsmuster"""

        if not TORCH_AVAILABLE:

            return None

        

        class ThreatNet(nn.Module):

            def __init__(self):

                super().__init__()

                self.encoder = nn.Sequential(

                    nn.Linear(7, 128),

                    nn.ReLU(),

                    nn.Dropout(0.3),

                    nn.Linear(128, 256),

                    nn.ReLU(),

                    nn.Dropout(0.2),

                    nn.Linear(256, 128),

                    nn.ReLU(),

                )

                self.classifier = nn.Sequential(

                    nn.Linear(128, 64),

                    nn.ReLU(),

                    nn.Linear(64, 3),  # 3 Klassen: Normal, Suspicious, Malicious

                    nn.Softmax(dim=1)

                )

            

            def forward(self, x):

                features = self.encoder(x)

                return self.classifier(features)

        

        return ThreatNet()

    

    def _build_ensemble(self) -> Pipeline:

        """Ensemble-Modell für robuste Klassifikation"""

        if not SKLEARN_AVAILABLE:

            return None

        

        return Pipeline([

            ('scaler', StandardScaler()),

            ('classifier', RandomForestClassifier(

                n_estimators=200,

                max_depth=20,

                min_samples_split=5,

                min_samples_leaf=2,

                class_weight='balanced',

                n_jobs=-1,

                random_state=42

            ))

        ])

    

    def _initialize_agents(self):

        """Initialisiert spezialisierte Defense Agents"""

        self.agents['packet_analyzer'] = DefenseAgent(

            name='packet_analyzer',

            specialty='network_packet_inspection',

            sensitivity=0.85

        )

        self.agents['behavior_profiler'] = DefenseAgent(

            name='behavior_profiler',

            specialty='user_behavior_analytics',

            sensitivity=0.90

        )

        self.agents['reputation_guard'] = DefenseAgent(

            name='reputation_guard',

            specialty='threat_intelligence',

            sensitivity=0.80

        )

        self.agents['entropy_detector'] = DefenseAgent(

            name='entropy_detector',

            specialty='payload_analysis',

            sensitivity=0.88

        )

        self.agents['timing_analyst'] = DefenseAgent(

            name='timing_analyst',

            specialty='side_channel_detection',

            sensitivity=0.92

        )

    

    async def analyze_threat(self, signature: ThreatSignature) -> Tuple[float, Dict[str, float]]:

        """

        Multi-Agent Consensus Analysis

        Gibt Bedrohungswert (0.0-1.0) und Agent-Votes zurück

        """

        agent_votes = {}

        

        # Parallele Agent-Analyse

        tasks = [

            self.agents['packet_analyzer'].evaluate(signature),

            self.agents['behavior_profiler'].evaluate(signature),

            self.agents['reputation_guard'].evaluate(signature),

            self.agents['entropy_detector'].evaluate(signature),

            self.agents['timing_analyst'].evaluate(signature),

        ]

        

        results = await asyncio.gather(*tasks, return_exceptions=True)

        

        for agent, result in zip(self.agents.values(), results):

            if isinstance(result, Exception):

                agent_votes[agent.name] = 0.5  # Neutral bei Fehler

            else:

                agent_votes[agent.name] = result

        

        # Gewichteter Konsens

        weights = {

            'packet_analyzer': 0.20,

            'behavior_profiler': 0.25,

            'reputation_guard': 0.20,

            'entropy_detector': 0.15,

            'timing_analyst': 0.20

        }

        

        consensus = sum(

            agent_votes[name] * weights[name] 

            for name in agent_votes

        )

        

        # Neural Network Override (falls verfügbar)

        if self.neural_net is not None and TORCH_AVAILABLE:

            with torch.no_grad():

                vector = torch.FloatTensor(signature.to_vector()).unsqueeze(0)

                nn_output = self.neural_net(vector)

                nn_threat = nn_output[0][2].item()  # Malicious-Klasse

                # Gewichtete Kombination

                consensus = 0.7 * consensus + 0.3 * nn_threat

        

        return min(consensus, 1.0), agent_votes

    

    async def update_behavioral_baseline(self, ip: str, signature: ThreatSignature):

        """Aktualisiert das Verhaltensprofil eines IPs"""

        self.behavioral_baseline[ip].append(signature.to_vector())

        

        # Federated Learning Update (periodisch)

        if len(self.behavioral_baseline[ip]) >= CONFIG.BEHAVIORAL_WINDOW_SIZE:

            await self._federated_update()

    

    async def _federated_update(self):

        """Verteiltes Lernen ohne Datenweitergabe"""

        async with self._model_lock:

            # Aggregation lokaler Modelle

            # In Produktion: Secure Aggregation Protocol

            pass


class DefenseAgent:

    """Einzelner Defense-Agent im Schwarm"""

    

    def __init__(self, name: str, specialty: str, sensitivity: float):

        self.name = name

        self.specialty = specialty

        self.sensitivity = sensitivity

        self.experience_buffer: deque = deque(maxlen=1000)

        self.confidence = 0.5

    

    async def evaluate(self, signature: ThreatSignature) -> float:

        """Bewertet eine Bedrohungssignatur (0.0 = sicher, 1.0 = kritisch)"""

        

        if self.specialty == 'network_packet_inspection':

            return self._analyze_packet(signature)

        elif self.specialty == 'user_behavior_analytics':

            return self._analyze_behavior(signature)

        elif self.specialty == 'threat_intelligence':

            return self._check_reputation(signature)

        elif self.specialty == 'payload_analysis':

            return self._analyze_entropy(signature)

        elif self.specialty == 'side_channel_detection':

            return self._analyze_timing(signature)

        

        return 0.5

    

    def _analyze_packet(self, sig: ThreatSignature) -> float:

        """Analysiert Paketmerkmale"""

        score = 0.0

        if sig.packet_size > 1400:  # Jumbo-Paket-Anomalie

            score += 0.3

        if sig.frequency > 50:  # Hohe Frequenz

            score += 0.4

        if sig.protocol_anomaly > 0.5:

            score += 0.3

        return min(score * self.sensitivity, 1.0)

    

    def _analyze_behavior(self, sig: ThreatSignature) -> float:

        """Verhaltensanalyse"""

        # Baseline Deviation Detection

        score = 0.0

        if sig.reputation_score < 0.3:

            score += 0.5

        if sig.geolocation_risk > 0.7:

            score += 0.3

        if sig.payload_entropy > 7.5:  # Verschlüsselter/Obfuskierter Traffic

            score += 0.2

        return min(score * self.sensitivity, 1.0)

    

    def _check_reputation(self, sig: ThreatSignature) -> float:

        """Prüft Reputation (Threat Intelligence)"""

        # In Produktion: Abfrage von Threat-Intelligence-Feeds

        base_risk = 1.0 - sig.reputation_score

        return min(base_risk * self.sensitivity, 1.0)

    

    def _analyze_entropy(self, sig: ThreatSignature) -> float:

        """Entropie-Analyse für Payload-Erkennung"""

        # Hohe Entropie = verdächtig (verschlüsselt oder komprimiert)

        entropy_risk = sig.payload_entropy / 8.0

        return min(entropy_risk * self.sensitivity, 1.0)

    

    def _analyze_timing(self, sig: ThreatSignature) -> float:

        """Timing-Analyse für Side-Channel-Erkennung"""

        if not sig.timing_pattern:

            return 0.5

        

        std_dev = np.std(sig.timing_pattern) if SKLEARN_AVAILABLE else 0.1

        if std_dev < 0.01:  # Zu regelmäßig = automatisiert

            return 0.8 * self.sensitivity

        if std_dev > 0.5:  # Zu unregelmäßig = Angriffsmuster

            return 0.6 * self.sensitivity

        return 0.2


